# ============================================================
# BlankTex — Docker deployment config (used by docker-compose)
# Target server: 31.97.110.197  →  http://31.97.110.197:8097
# ============================================================

# Public port the app is served on (host:8097 -> nginx:80)
APP_PORT=8097

# PostgreSQL credentials (internal to the docker network — DB port is NOT exposed)
POSTGRES_USER=blanktex
POSTGRES_PASSWORD=blanktex_secret
POSTGRES_DB=blanktex
