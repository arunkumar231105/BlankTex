# ============================================================
# BlankTex — Docker deployment config
# Copy this file to ".env" and set a real password:
#     cp .env.example .env
# The real .env is git-ignored and must NEVER be committed.
# ============================================================

# Public port the app is served on (host:PORT -> nginx:80)
APP_PORT=8097

# PostgreSQL (internal to the docker network — DB port is NOT exposed publicly)
POSTGRES_USER=blanktex
POSTGRES_DB=blanktex
# Set your own strong password here (required — compose will not start without it):
POSTGRES_PASSWORD=change_me_to_a_strong_password

# Initial BlankTex administrator. These values stay on the server in .env.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_to_a_long_unique_password
